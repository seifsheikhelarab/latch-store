{
  "name": "latch-store",
  "version": "0.2.2",
  "description": "Idempotency middleware for your HTTP framework",
  "license": "MIT",
  "author": "seifsheikhelarab",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18",
    "bun": ">=1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/seifsheikhelarab/latch-store.git"
  },
  "scripts": {
    "build": "tsc",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "bench": "bun run src/benchmark.ts",
    "prepack": "bun run build"
  },
  "peerDependencies": {
    "ioredis": "^5.11.1"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "bun-types": "^1.3.14",
    "hono": "^4.12.29",
    "typescript": "^7.0.2"
  }
}
